TGDL_HOST=0.0.0.0
TGDL_PORT=9910
TGDL_STATE_DIR=/etc/tg-downloader-ui
TGDL_DOWNLOAD_DIR=/mnt/telegram-downloads
TGDL_TDL_BIN=/usr/bin/tdl
TGDL_TDL_STORAGE=type=bolt,path=/etc/tg-downloader-ui/tdl/data
TGDL_TDL_LOG=/etc/tg-downloader-ui/tdl.log
TGDL_PROXY=
TGDL_TDL_PROXY=
TGDL_TELEGRAM_PROXY=
TGDL_SESSION_MAX_AGE=604800
TGDL_COOKIE_SECURE=0
TGDL_FORWARDER_ENABLED=0

# Required only for the optional forwarder service.
TGDL_API_ID=
TGDL_API_HASH=
TGDL_SESSION_FILE=/etc/tg-downloader-ui/session.txt
TGDL_FORWARD_SOURCE=
TGDL_FORWARD_CHANNEL_ID=
TGDL_FORWARDER_LOG=/etc/tg-downloader-ui/forwarder.log
TGDL_FORWARDER_STATUS=/etc/tg-downloader-ui/forwarder_status.json
TGDL_FORWARDER_RESTART_CMD=
